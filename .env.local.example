# ── Stripe (copy to .env.local — do NOT commit .env.local!) ──────────────────
# Get your real keys from https://dashboard.stripe.com/apikeys
#
# The secret key below is intentionally obfuscated so that GitHub
# secret-scanner doesn't flag this template file.  Replace each field
# with your own credentials before running locally or in Vercel.
#
STRIPE_SECRET_KEY=<put_your_stripe_secret_key_here>
STRIPE_PUBLISHABLE_KEY=<put_your_stripe_publishable_key_here>

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Create 3 recurring price products in Stripe and paste the IDs here.
STRIPE_PRICE_NEXUS_MONTHLY=<price_id_nexus_monthly>
STRIPE_PRICE_NEXUS_ANNUAL=<price_id_nexus_annual>
STRIPE_PRICE_APEX_MONTHLY=<price_id_apex_monthly>
STRIPE_PRICE_APEX_ANNUAL=<price_id_apex_annual>
STRIPE_PRICE_CIRCADIAN_MONTHLY=<price_id_circadian_monthly>
STRIPE_PRICE_CIRCADIAN_ANNUAL=<price_id_circadian_annual>

# ── Webhook ──────────────────────────────────────────────────────────────────
# Create a webhook endpoint in https://dashboard.stripe.com/webhooks
# Point it at https://your-deployment.vercel.app/api/stripe-webhook
# Select events: checkout.session.completed, invoice.payment_succeeded,
#               invoice.payment_failed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=<webhook_secret_here>

# ── Next.js ───────────────────────────────────────────────────────────────────
# Override with your Vercel URL after deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
